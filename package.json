{
  "name": "votelens-ai",
  "version": "1.0.0",
  "description": "VoteLens AI — An AI Election Mentor that Simulates, Explains, and Verifies Elections",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testMatch=\"**/?(*.)+(spec|test).[jt]s?(x)\"",
    "lint": "eslint ."
  },
  "keywords": [
    "election",
    "voting",
    "gemini",
    "ai",
    "education"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jest": "^29.7.0"
  }
}
