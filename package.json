{
  "name": "votelens-ai",
  "version": "1.0.0",
  "description": "VoteLens AI — An AI Election Mentor that Simulates, Explains, and Verifies Elections",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "lint": "eslint ."
  },
  "keywords": ["election", "voting", "gemini", "ai", "education"],
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0"
  }
}
